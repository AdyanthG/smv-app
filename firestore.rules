rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Users Collection ──
    match /users/{userId} {
      // Anyone signed in can read user profiles (for leaderboard, profile views)
      allow read: if isSignedIn();

      // Only the user can write their own profile
      allow create: if isOwner(userId);
      // Allow own profile updates, OR follower/vote count updates from any signed-in user
      allow update: if isOwner(userId)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['followerCount', 'voteWins', 'voteLosses']));
      allow delete: if isOwner(userId);

      // ── Following subcollection ──
      match /following/{targetId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId);
      }

      // ── Followers subcollection ──
      match /followers/{followerId} {
        allow read: if isSignedIn();
        // Followers are written by the follower (via batch), so check the follower
        allow create, delete: if isSignedIn() && request.auth.uid == followerId;
      }

      // ── Saved posts (bookmarks) subcollection ──
      match /saved/{postId} {
        // Only the owner can read or modify their own saved posts
        allow read, create, delete: if isOwner(userId);
      }

      // ── Blocked users subcollection ──
      match /blocked/{blockedId} {
        // Only the owner can see or manage who they've blocked
        allow read, create, delete: if isOwner(userId);
      }
    }

    // ── Apple auth codes (Sign in with Apple revocation) ──
    match /appleAuthCodes/{userId} {
      // The user drops their short-lived code here; a Cloud Function consumes it.
      allow create: if isOwner(userId);
      allow read, update, delete: if false;
    }

    // ── Reports Collection (content moderation) ──
    match /reports/{reportId} {
      // Any signed-in user can file a report; only the reporter is recorded.
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid;
      // Reports are reviewed server-side; clients cannot read or modify them.
      allow read, update, delete: if false;
    }

    // ── Scans Collection ──
    match /scans/{scanId} {
      // Any signed-in user can read scans (needed for feed/leaderboard/profile views)
      allow read: if isSignedIn();

      // Users can create scans for themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Scan results are immutable, but the owner may delete them (account deletion)
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Posts Collection ──
    match /posts/{postId} {
      // Anyone signed in can read public posts
      allow read: if isSignedIn();

      // Users can create posts with their own authorId
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      // Only the author can update/delete
      allow update, delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;

      // ── Likes subcollection ──
      match /likes/{likeUserId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && likeUserId == request.auth.uid;
      }

      // ── Comments subcollection ──
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if isSignedIn()
          && resource.data.authorId == request.auth.uid;
      }
    }

    // ── Threads Collection ──
    match /threads/{threadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Only author can update/delete, but allow like/reply count increments from anyone
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;
    }

    // ── Replies Collection ──
    match /replies/{replyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow like count updates from anyone signed in
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && resource.data.authorId == request.auth.uid;
    }
  }
}
